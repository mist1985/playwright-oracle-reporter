# Playwright Oracle Reporter - Environment Variables
# Copy this file to .env and fill in your values

# AI Mode Configuration
# Options: auto, rules, openai, off
# - auto: Use OpenAI if API key is present, otherwise rules-only
# - rules: Pure rules-based analysis (no API calls)
# - openai: Require OpenAI (fails if API key missing)
# - off: Minimal reporting
PW_AI_AI_MODE=auto

# OpenAI Configuration (Optional)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-abc123...
PW_AI_OPENAI_MODEL=gpt-4o

# Output Directories (Optional)
# PW_AI_OUTPUT_DIR=pw-ai-report
# PW_AI_HISTORY_DIR=.pw-ai-history

# Telemetry Configuration (Optional)
# PW_AI_TELEMETRY_INTERVAL=15

# Thresholds (Optional)
# PW_AI_THRESHOLD_LOAD1=4.0
# PW_AI_THRESHOLD_STEAL=5.0

# Run Label (Optional)
# PW_AI_RUN_LABEL=CI-Build-123

# Dotenv Autoload (optional)
# If installing dotenv changed nothing, you're likely not loading it.
# You can autoload dotenv without touching code by setting NODE_OPTIONS:
# macOS/Linux (before running tests):
#   export NODE_OPTIONS="-r dotenv/config"
# Windows PowerShell:
#   $env:NODE_OPTIONS="-r dotenv/config"
# npm script example:
#   "test": "NODE_OPTIONS='-r dotenv/config' playwright test"

# TROUBLESHOOTING
# If AI analysis isn't working after adding your API key:
# 1. Verify this file is copied to .env (not .env.example)
# 2. Ensure .env is in the same directory as playwright.config.ts
# 3. Add require('dotenv').config() to the TOP of playwright.config.ts
# 4. Restart your terminal/IDE after changing .env
# 5. Check PW_AI_AI_MODE is set to 'auto' or 'openai'
# 6. API key should have no quotes: OPENAI_API_KEY=sk-proj-abc123...
# 7. Run with DEBUG=pw:api to see if env vars are loaded

# Remember: copy this file to .env and fill in real values.

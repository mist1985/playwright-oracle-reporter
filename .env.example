# Playwright Oracle Reporter environment variables
# Copy this file to .env and replace example values with your own.

# AI mode
# Options: auto, rules, openai, off
PW_ORACLE_AI_MODE=auto

# Optional OpenAI settings
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
PW_ORACLE_OPENAI_MODEL=gpt-4o

# Optional output settings
# PW_ORACLE_OUTPUT_DIR=playwright-oracle-report
# PW_ORACLE_HISTORY_DIR=.playwright-oracle-history
# PW_ORACLE_OPEN_REPORT=false

# Optional telemetry settings
# PW_ORACLE_TELEMETRY_INTERVAL=15

# Optional run labeling
# PW_ORACLE_RUN_LABEL=CI-Build-123

# Notes
# - Do not commit your real .env file.
# - OPENAI_API_KEY should be a real runtime secret, not stored in source control.
# - Legacy PW_AI_* variables are still supported, but new configs should use PW_ORACLE_*.

# Playwright Oracle Reporter environment variables
# Copy this file to .env and replace example values with your own.

# AI mode
# Options: auto (tries OpenAI, falls back to Claude), rules, openai, claude, off
PW_ORACLE_AI_MODE=auto

# Optional OpenAI settings
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
PW_ORACLE_OPENAI_MODEL=gpt-4o
# PW_ORACLE_OPENAI_MAX_TOKENS=1000
# PW_ORACLE_OPENAI_TIMEOUT_MS=30000

# Optional Claude settings
# Get your API key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
PW_ORACLE_CLAUDE_MODEL=claude-sonnet-4-20250514
# PW_ORACLE_CLAUDE_MAX_TOKENS=4000
# PW_ORACLE_CLAUDE_TIMEOUT_MS=30000

# Optional output settings
# PW_ORACLE_OUTPUT_DIR=playwright-oracle-report
# PW_ORACLE_HISTORY_DIR=.playwright-oracle-history
# PW_ORACLE_OPEN_REPORT=false

# Optional telemetry settings
# PW_ORACLE_TELEMETRY_INTERVAL=15

# Optional run labeling
# PW_ORACLE_RUN_LABEL=CI-Build-123

# Notes
# - Do not commit your real .env file.
# - OPENAI_API_KEY and ANTHROPIC_API_KEY should be real runtime secrets, not stored in source control.
# - aiMode "auto" prefers OpenAI when OPENAI_API_KEY is set, otherwise tries Claude.
# - Set either OPENAI_API_KEY or ANTHROPIC_API_KEY (or both) to enable AI enrichment.
# - Legacy PW_AI_* variables are still supported, but new configs should use PW_ORACLE_*.
